generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:pass@localhost:5432/mydb?schema=jimmys"
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  type        TransactionType
  description String?
  amount      Float
  completedAt DateTime
  fundsId     String?         @db.Uuid
  funds       Funds?          @relation(fields: [fundsId], references: [id])
  paymentMethod PaymentMethod @default(CARD)
  cardId      String?         @db.Uuid
  card        Card?           @relation(fields: [cardId], references: [id])

  @@index([type])
}

model Reason {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  funds       Funds[]
  goal        Goal? // One reason can have one goal
}

model Funds {
  id           String        @id @default(uuid()) @db.Uuid
  amount       Float
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reasonId     String        @db.Uuid
  reason       Reason        @relation(fields: [reasonId], references: [id])
  transactions Transaction[]
}

model History {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CurrentBalance {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Float // Current balance in the main account
  updatedAt DateTime @updatedAt // Timestamp of the most recent update to this balance
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  description String
  amount      Float // Target amount
  type        GoalType
  status      GoalStatus
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  reasonId    String     @unique @db.Uuid
  reason      Reason     @relation(fields: [reasonId], references: [id], onDelete: Cascade)
}

model Balance {
  id        String   @id @db.Uuid
  amount    Float
  updatedAt DateTime
}

model Subscription {
  id           String                @id @default(uuid()) @db.Uuid
  type         TransactionType
  description  String?
  amount       Float
  frequency    SubscriptionFrequency
  startDate    DateTime
  endDate      DateTime?
  lastExecuted DateTime?
  active       Boolean               @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  paymentMethod PaymentMethod       @default(CARD)
  cardId       String?              @db.Uuid
  card         Card?                @relation(fields: [cardId], references: [id])
}

enum TransactionType {
  income
  expense
  fund
}

enum GoalType {
  LIMIT
  SAVINGS
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  ACHIEVED
  FAILED
}

enum SubscriptionFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
}

enum CardType {
  DEBIT
  CREDIT
}

model Card {
  id          String         @id @default(uuid()) @db.Uuid
  name        String
  type        CardType
  lastFourDigits String      @db.VarChar(4)
  expiryDate  DateTime
  isDefault   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  transactions Transaction[]
  subscriptions Subscription[]
}
