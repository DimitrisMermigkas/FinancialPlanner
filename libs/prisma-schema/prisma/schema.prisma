generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  type        TransactionType
  description String?
  amount      Float
  completedAt DateTime
  fundsId     String?         @db.Uuid
  funds       Funds?          @relation(fields: [fundsId], references: [id])

  @@index([type])
}

model Reason {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  funds       Funds[]
}

model Funds {
  id           String        @id @default(uuid()) @db.Uuid
  amount       Float
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reasonId     String        @db.Uuid
  reason       Reason        @relation(fields: [reasonId], references: [id])
  transactions Transaction[]
}

model History {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CurrentBalance {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Float // Current balance in the main account
  updatedAt DateTime @updatedAt // Timestamp of the most recent update to this balance
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  description String
  amount      Float
  type        GoalType
  status      GoalStatus
  createdAt   DateTime   @default(now())
}

model BalanceHistory {
  id        String   @id @db.Uuid
  amount    Float
  updatedAt DateTime
  createdAt DateTime @default(now())
}

model Balance {
  id        String   @id @db.Uuid
  amount    Float
  updatedAt DateTime
}

enum TransactionType {
  income
  expense
  fund
}

enum GoalType {
  LIMIT
  SAVINGS
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  ACHIEVED
  FAILED
}
