{
  "name": "prisma-schema",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/prisma-schema",
  "projectType": "library",
  "targets": {
    "validate": {
      "command": "prisma validate",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "prisma": {
      "command": "prisma",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "generate-types": {
      "command": "prisma generate",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "migrate": {
      "command": "prisma migrate dev --name m",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "db-push": {
      "command": "prisma db push --force-reset",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "db-seed": {
      "command": "prisma db seed",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    },
    "db-execute": {
      "command": "prisma db execute",
      "options": {
        "cwd": "libs/prisma-schema"
      }
    }
  },
  "tags": []
}
