generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:mitchigun15@localhost:5432/mydb?schema=jimmys"
}

enum TransactionType {
  income // Money coming in
  expense // Money going out
  fund // Money set aside in Funds (not considered an expense)
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  type        TransactionType // "income", "expense", or "fund"
  description String? // Description of the transaction (e.g., "Salary", "Groceries", "Savings")
  amount      Float // Amount of the transaction
  completedAt DateTime // Date of the transaction
  fundsId     String?         @db.Uuid // Optional link to Funds if this is a "fund" transaction
  funds       Funds?          @relation(fields: [fundsId], references: [id])

  @@index([type])
}

model Reason {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  funds       Funds[]
}

model Funds {
  id           String        @id @default(uuid()) @db.Uuid
  amount       Float
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reasonId     String        @db.Uuid // Foreign key to Reason
  reason       Reason?       @relation(fields: [reasonId], references: [id])
  transactions Transaction[]
}

model Balance {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Float // Current balance in the main account
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  description String // Reason/description for the goal
  amount      Float // The target amount for the goal (could be a limit or deposit)
  type        GoalType // Enum to define the type of goal (deposit, limit, etc.)
  status      GoalStatus // Enum to define the status of the goal
  createdAt   DateTime   @default(now())
}

enum GoalType {
  LIMIT
  SAVINGS
}

enum GoalStatus {
  PENDING // Goal has not been achieved yet
  IN_PROGRESS // Goal is currently being worked on
  ACHIEVED // Goal has been reached
  FAILED // Goal could not be reached
}
